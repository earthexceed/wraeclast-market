<Modal
  @title={{t "page.bookmarks.folder-edition.modal-title"}}
  @onClose={{fn @onCancel}}
>
  <Form::Container
    @submitTask={{@submitTask}}
    @entity={{this.folder}}
    @canSubmit={{this.canSubmit}}
  >
    <Form::Input
      @label={{t "page.bookmarks.folder-edition.title-label"}}
      @value={{this.folder.title}}
      @autofocus={{true}}
      @onChange={{fn this.changeTitle}}
    />

    <Form::Field @label={{t "page.bookmarks.folder-edition.icon-label"}}>
      <ul local-class="icon-options with-items">
        {{#each this.iconItemOptions as |itemOption|}}
          <li
            {{on "click" (fn this.toggleIcon itemOption.value)}}
            local-class="icon-option {{if (eq itemOption.value this.folder.icon) "is-selected"}}"
          >
            <img
              local-class="icon-option-image"
              src={{image-resource-url itemOption.imagePath}}
              alt={{itemOption.value}}
            >
          </li>
        {{/each}}
      </ul>

      <ul local-class="icon-options with-ascendancies">
        {{#each this.iconAscendancyOptions as |ascendancyOption|}}
          <li
            {{on "click" (fn this.toggleIcon ascendancyOption.value)}}
            local-class="icon-option is-named {{if (eq ascendancyOption.value this.folder.icon) "is-selected"}}"
            title={{ascendancyOption.label}}
          >
            <img
              local-class="icon-option-image"
              src={{image-resource-url ascendancyOption.imagePath}}
              alt={{ascendancyOption.label}}
            >
            <span local-class="icon-option-label">{{ascendancyOption.label}}</span>
          </li>
        {{/each}}
      </ul>
    </Form::Field>

    <Button
      type="submit"
      @theme="gold"
      @label={{t "page.bookmarks.folder-edition.save"}}
      @icon="save"
    />
  </Form::Container>
</Modal>
